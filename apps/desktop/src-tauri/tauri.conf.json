{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Grok GUI",
  "version": "0.1.0",
  "identifier": "com.grok-gui.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Grok GUI",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Visible",
        "fullscreen": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$HOME/**", "$TEMP/**"],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "style-src": "'self' 'unsafe-inline'"
      },
      "devCsp": "default-src 'self' http://localhost:1420; connect-src 'self' http://localhost:1420 ws://localhost:1420 ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost blob: data:; style-src 'self' 'unsafe-inline' http://localhost:1420; script-src 'self' 'unsafe-eval' http://localhost:1420"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Time星沁",
    "copyright": "Copyright © 2026 Time星沁",
    "license": "MIT",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Grok GUI desktop client for Grok Build",
    "longDescription": "Grok GUI is a desktop interface for the Grok Build AI coding agent. Multi-provider, multi-model, with Code and Write modes. Inspired by OpenCode, Codex, and DeepSeek GUI.",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": null,
      "exceptionDomain": "",
      "signingIdentity": "-",
      "providerShortName": null,
      "dmg": {
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI4ODk1Qjk3OEZEOTAzQ0EKUldUS0E5bVBsMXVKdUZRNGZMVkJVV3RiZ3FiMWNyZm5FT2xTdC9yMHNiRUR5UDJvYVhRS0hWSWQK",
      "endpoints": [
        "https://github.com/timexingxin/grok-gui/releases/latest/download/latest.json"
      ],
      "windows": { "installMode": "passive" }
    }
  }
}
