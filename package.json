{
  "name": "grok-gui",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform desktop GUI for Grok Build — multi-provider AI coding & writing agent.",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "tauri:dev": "npm -w @grok-gui/desktop exec -- tauri dev",
    "tauri:build": "npm -w @grok-gui/desktop exec -- tauri build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.0"
}
